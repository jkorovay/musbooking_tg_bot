# Пример переменных окружения для MusBooking Bot.
# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env

# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# Telegram ID пользователей, которым разрешён доступ к боту (через запятую).
# Узнать свой ID можно у @userinfobot.
ALLOWED_IDS=

# ID администратора — получает отчёты об ошибках отправки.
# Обычно это один из ID из ALLOWED_IDS.
ADMIN_ID=

# Приватные идентификаторы студии на платформе MusBooking (обязательно).
# ROOM_ID — ID комнаты; OPTION_ID — ID опции бронирования.
# Берутся из личного кабинета студии на partner.musbooking.com.
# В репозиторий не кладутся — это данные конкретной студии.
ROOM_ID=
OPTION_ID=
